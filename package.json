{
  "name": "lunch-plans",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "portless lunch-plans ng serve",
    "start:es": "portless lunch-plans ng serve --configuration=es",
    "build": "ng build --configuration production",
    "build:gh-page": "ng build --base-href=lunch-plans",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --browsers=ChromeHeadless --watch=false",
    "test:watch": "ng test --browsers=ChromeHeadless --watch=true",
    "serve:ssr:lunch-plans": "node dist/lunch-plans/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.2",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.2.2",
    "@angular/compiler": "^21.2.2",
    "@angular/core": "^21.2.2",
    "@angular/forms": "^21.2.2",
    "@angular/material": "^21.2.1",
    "@angular/platform-browser": "^21.2.2",
    "@angular/platform-browser-dynamic": "^21.2.2",
    "@angular/router": "^21.2.2",
    "hammerjs": "^2.0.8",
    "ng": "^0.0.0",
    "@angular/platform-server": "^21.2.2",
    "@angular/ssr": "^21.2.2",
    "express": "^5.1.0",
    "rxjs": "^7.8.1",
    "tslib": "^2.1.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.2",
    "@angular/localize": "^21.2.2",
    "@types/express": "^5.0.1",
    "@types/hammerjs": "^2.0.41",
    "@types/jasmine": "~3.6.0",
    "@types/node": "^20.17.19",
    "karma": "^6.3.20",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.0.3",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.5.0",
    "typescript": "~5.9.3"
  }
}
