{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "rewrites": [
        {
            "source": "/",
            "destination": "/en-US/index.csr.html"
        },
        {
            "source": "/es",
            "destination": "/es/index.csr.html"
        },
        {
            "source": "(.*)",
            "destination": "/en-US/index.csr.html"
        }
    ]
}
